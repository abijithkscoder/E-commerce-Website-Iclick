# Base URL of the Django backend API (include the trailing /api/).
# Local development can leave this unset; the Vite dev server proxies /api and
# /media to http://127.0.0.1:8000 automatically.
#
# In production (e.g. Vercel) set this to your deployed backend, for example:
# VITE_API_BASE_URL=https://ecommerce-backend.onrender.com/api/
VITE_API_BASE_URL=
